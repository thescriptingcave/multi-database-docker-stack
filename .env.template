# ============================================================
#  .env — Docker Compose environment variables
#  Copy this file to .env and fill in your own values.
#  NEVER commit .env to version control.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=pguser
POSTGRES_PASSWORD=changeme_pg
POSTGRES_DB=mydb

# ── pgAdmin ──────────────────────────────────────────────────
# Use any valid email address as the login username
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=changeme_pgadmin

# ── MongoDB ──────────────────────────────────────────────────
MONGO_ROOT_USER=mongouser
MONGO_ROOT_PASSWORD=changeme_mongo
MONGO_DB=mydb

# ── Azure SQL Edge (SQL Server) ──────────────────────────────
# Minimum complexity requirements:
#   • At least 8 characters
#   • Must contain uppercase, lowercase, digit AND special char
MSSQL_SA_PASSWORD=Changeme_mssql1!
